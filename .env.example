# Anthropic API key powers the live multilingual chatbot (§6.7).
# Get one at https://console.anthropic.com — set in .env.local for dev and in Vercel project env for prod.
ANTHROPIC_API_KEY=

# Optional: override the chat model (defaults to claude-opus-4-8, the flagship).
# Set to claude-sonnet-4-6 for lower latency/cost on high-volume traffic.
CHAT_MODEL=claude-opus-4-8
