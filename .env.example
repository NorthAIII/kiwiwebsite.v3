# Groq API key powers the live multilingual chatbot (§6.7).
# Get one at https://console.groq.com — set in .env.local for dev and in Vercel project env for prod.
GROQ_API_KEY=

# Optional: override the chat model (defaults to llama-3.3-70b-versatile).
# See https://console.groq.com/docs/models for other Groq production models.
CHAT_MODEL=llama-3.3-70b-versatile
